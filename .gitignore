# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
ENV/
env/

# Generated outputs (regenerated by pipeline)
out/endpoint-index.json
out/frontend-calls.json
out/merged-params.json
out/mismatch-report.json
out/passthru-resolved.json
out/domain/*.json
out/*-*.json

# Generated documentation (deployed via GitHub Pages)
out/docs/

# Keep example outputs for documentation
!out/coverage-report.json
!out/openapi.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
.cache/

# Local backup artifacts (created by enrich_sidecars.py --apply before modifying sidecars/)
# Not useful to commit — git history already provides version control for sidecar changes
sidecars_backup/

# Sidecar templates staging area (created by scripts during development — not canonical)
sidecar_templates/

# Superpowers specs and plans (local development artifacts, not part of the tool)
docs/superpowers/
