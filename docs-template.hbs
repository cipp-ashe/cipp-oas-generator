<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- Primary Meta Tags -->
    <title>{{title}}</title>
    <meta name="title" content="CIPP API Documentation" />
    <meta name="description" content="Interactive API documentation for CIPP (CyberDrain Improved Partner Platform) - A comprehensive MSP management platform for Microsoft 365 environments." />
    <meta name="keywords" content="CIPP, CyberDrain, MSP, Microsoft 365, API, Documentation, Partner Platform, Azure, Intune, Exchange" />
    <meta name="author" content="CyberDrain" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cipp-ashe.github.io/cipp-oas-generator/" />
    <meta property="og:title" content="CIPP API Documentation" />
    <meta property="og:description" content="Interactive API documentation for CIPP - A comprehensive MSP management platform for Microsoft 365 environments." />
    <meta property="og:image" content="https://cipp-ashe.github.io/cipp-oas-generator/assets/cipp-social.png" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://cipp-ashe.github.io/cipp-oas-generator/" />
    <meta property="twitter:title" content="CIPP API Documentation" />
    <meta property="twitter:description" content="Interactive API documentation for CIPP - A comprehensive MSP management platform for Microsoft 365 environments." />
    <meta property="twitter:image" content="https://cipp-ashe.github.io/cipp-oas-generator/assets/cipp-social.png" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="./assets/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="./assets/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="./assets/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="./assets/apple-touch-icon.png" />
    
    <!-- Theme Color - CyberDrain Navy -->
    <meta name="theme-color" content="#003049" />
    <meta name="msapplication-TileColor" content="#003049" />
    
    <!-- Inter Font - Same as CIPP UI -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://cdn.redoc.ly" crossorigin />
    
    <!-- Custom CSS for CIPP branding -->
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        margin: 0;
        padding: 0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
        background-color: #F0F2F5;
        color: #101828;
      }
      
      /* Loading screen - CIPP styled */
      .loading-screen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #003049 0%, #004d6d 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        transition: opacity 0.3s ease-out;
      }
      
      .loading-screen.hidden {
        opacity: 0;
        pointer-events: none;
      }
      
      .loading-logo {
        font-size: 56px;
        font-weight: 700;
        color: #F77F00;
        margin-bottom: 16px;
        letter-spacing: 3px;
        font-family: 'Inter', sans-serif;
        text-shadow: 0 2px 20px rgba(247, 127, 0, 0.3);
      }
      
      .loading-subtitle {
        font-size: 16px;
        font-weight: 500;
        color: #FFFFFF;
        margin-bottom: 32px;
        opacity: 0.9;
        letter-spacing: 1px;
      }
      
      .loading-spinner {
        width: 50px;
        height: 50px;
        border: 4px solid rgba(247, 127, 0, 0.2);
        border-top-color: #F77F00;
        border-radius: 50%;
        animation: spin 1s linear infinite;
      }
      
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
      
      .loading-text {
        margin-top: 24px;
        color: rgba(255, 255, 255, 0.8);
        font-size: 14px;
        font-weight: 400;
      }
      
      /* Custom scrollbar - CIPP styled */
      ::-webkit-scrollbar {
        width: 7px;
        height: 7px;
      }
      
      ::-webkit-scrollbar-track {
        background: #F0F2F5;
      }
      
      ::-webkit-scrollbar-thumb {
        background: #98A2B3;
        border-radius: 4px;
      }
      
      ::-webkit-scrollbar-thumb:hover {
        background: #667085;
      }
      
      /* Print styles */
      @media print {
        .loading-screen {
          display: none !important;
        }
      }
    </style>
  </head>
  
  <body>
    <!-- Loading Screen -->
    <div class="loading-screen" id="loadingScreen">
      <div class="loading-logo">CIPP</div>
      <div class="loading-subtitle">API Documentation</div>
      <div class="loading-spinner"></div>
      <div class="loading-text">Loading documentation...</div>
    </div>
    
    <!-- Redoc Container -->
    <div id="redoc-container">{{{redocHTML}}}</div>
    
    <!-- Hide loading screen once content is loaded -->
    <script>
      window.addEventListener('load', function() {
        const loadingScreen = document.getElementById('loadingScreen');
        setTimeout(function() {
          loadingScreen.classList.add('hidden');
          setTimeout(function() {
            loadingScreen.style.display = 'none';
          }, 300);
        }, 500);
      });
    </script>
  </body>
</html>
