{
  "override_synopsis": "ExecOffboardUser",
  "override_description": "Offboard a user with configurable options for mailbox conversion, access delegation, license removal, and more",
  "override_confidence": "high",
  "add_params": [
    {
      "name": "tenantFilter",
      "in": "body",
      "required": true,
      "type": "string",
      "description": "Target tenant domain"
    },
    {
      "name": "user",
      "in": "body",
      "required": true,
      "type": "array",
      "description": "Array of user principal names to offboard"
    },
    {
      "name": "ConvertToShared",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Convert user mailbox to shared mailbox"
    },
    {
      "name": "HideFromGAL",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Hide mailbox from Global Address List"
    },
    {
      "name": "removeCalendarInvites",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove calendar invites for the user"
    },
    {
      "name": "removePermissions",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove mailbox permissions granted to the user"
    },
    {
      "name": "removeCalendarPermissions",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove calendar permissions granted to the user"
    },
    {
      "name": "RemoveRules",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove mailbox rules"
    },
    {
      "name": "RemoveMobile",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove mobile device associations"
    },
    {
      "name": "RemoveGroups",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove user from all groups"
    },
    {
      "name": "RemoveLicenses",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove all licenses from the user"
    },
    {
      "name": "RevokeSessions",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Revoke all active sessions"
    },
    {
      "name": "DisableSignIn",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Disable user sign-in"
    },
    {
      "name": "ClearImmutableId",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Clear the ImmutableId (on-premises sync attribute)"
    },
    {
      "name": "ResetPass",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Reset user password"
    },
    {
      "name": "RemoveMFADevices",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove all MFA devices"
    },
    {
      "name": "RemoveTeamsPhoneDID",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Remove Teams phone number assignment"
    },
    {
      "name": "DeleteUser",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Permanently delete the user account"
    },
    {
      "name": "AccessNoAutomap",
      "in": "body",
      "required": false,
      "type": "LabelValue",
      "description": "Grant mailbox access without automapping (user selection)"
    },
    {
      "name": "AccessAutomap",
      "in": "body",
      "required": false,
      "type": "LabelValue",
      "description": "Grant mailbox access with automapping (user selection)"
    },
    {
      "name": "OnedriveAccess",
      "in": "body",
      "required": false,
      "type": "LabelValue",
      "description": "Grant OneDrive access (user selection)"
    },
    {
      "name": "forward",
      "in": "body",
      "required": false,
      "type": "string",
      "description": "Email address to forward mail to"
    },
    {
      "name": "disableForwarding",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Disable mail forwarding"
    },
    {
      "name": "KeepCopy",
      "in": "body",
      "required": false,
      "type": "boolean",
      "description": "Keep copy of forwarded messages in mailbox"
    },
    {
      "name": "OOO",
      "in": "body",
      "required": false,
      "type": "string",
      "description": "Out of office message"
    },
    {
      "name": "Scheduled",
      "in": "body",
      "required": false,
      "type": "ScheduledTask",
      "description": "Schedule offboarding for a future time"
    },
    {
      "name": "PostExecution",
      "in": "body",
      "required": false,
      "type": "PostExecution",
      "description": "Post-execution notifications"
    },
    {
      "name": "reference",
      "in": "body",
      "required": false,
      "type": "string",
      "description": "Reference identifier for tracking"
    }
  ],
  "trust_level": "tested",
  "tested_version": "v10.0.0"
}
